# Environment Variables Template for AWS Amplify Deployment
# Copy this file to .env.local and fill in your actual values
# These variables will be configured in AWS Amplify Console

# Application Configuration
VITE_APP_NAME=Marko React App
VITE_APP_VERSION=1.0.0

# API Configuration (if needed)
# VITE_API_BASE_URL=https://api.example.com
# VITE_API_KEY=your-api-key-here

# Analytics Configuration (if needed)
# VITE_GOOGLE_ANALYTICS_ID=GA-XXXXXXXXX
# VITE_FACEBOOK_PIXEL_ID=your-pixel-id

# Feature Flags (if needed)
# VITE_ENABLE_FEATURE_X=true
# VITE_ENABLE_DEBUG_MODE=false

# Third-party Service Configuration (if needed)
# VITE_STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxx
# VITE_MAPBOX_ACCESS_TOKEN=pk.xxxxxxxxx

# Build Configuration
NODE_ENV=production